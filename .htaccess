Options -MultiViews
DirectoryIndex index.html

RewriteEngine On

# The home page has one canonical URL.
RewriteCond %{THE_REQUEST} \s/+index\.html(?:[\s?]) [NC]
RewriteRule ^index\.html$ https://%{HTTP_HOST}/ [R=301,L,NE]

RewriteRule ^index/?$ https://%{HTTP_HOST}/ [R=301,L,NE]

# Redirect every public *.html request to its extensionless canonical URL.
# THE_REQUEST prevents a loop after the internal rewrite below.
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html(?:[\s?]) [NC]
RewriteRule ^(.+)\.html$ https://%{HTTP_HOST}/$1 [R=301,L,NE]

# Normalize an unnecessary trailing slash on extensionless file routes.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ https://%{HTTP_HOST}/$1 [R=301,L,NE]

# Serve the existing static HTML file for an extensionless request.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]
